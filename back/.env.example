GROQ_API_KEY=

# Server
PORT=4000
# CORS_ORIGIN=http://localhost:3000

# MongoDB Atlas (recommended for deployment)
MONGODB_URI=
MONGODB_DB=app
MONGODB_COLLECTION=chats
# Optional: require MongoDB on startup (otherwise falls back to file store)
# MONGODB_REQUIRED=true

# Optional: where to store local JSON chats when MONGODB_URI is NOT set
# CHATS_DIR=chats
